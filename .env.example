# Локально — SQLite (как раньше) или Neon/Postgres
# Для SQLite временно смените provider в prisma/schema.prisma на "sqlite"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
AUTH_SECRET="haymarket-dev-secret-change-in-production"

# Загрузка фото — обязательно на Render
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
