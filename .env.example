# === Supabase + Render (обязательно Session pooler, НЕ прямой db.*.supabase.co) ===
# Supabase Dashboard → Connect → Session pooler → URI

DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require"

AUTH_SECRET="haymarket-dev-secret-change-in-production"
SETUP_SECRET="setup-change-in-production"
INTERNAL_SOCKET_SECRET="socket-secret-change-in-production"

# Загрузка фото — опционально на старте
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Socket CORS — через запятую (на Render: https://your-app.onrender.com)
ALLOWED_ORIGINS="http://localhost:3000"

# AI-оценка цены авто (опционально)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# SMS верификация (опционально)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Продвижение — Stripe (опционально, без ключа demo-оплата)
STRIPE_SECRET_KEY=""

# Rate limit на нескольких инстансах (опционально, Upstash free tier)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

