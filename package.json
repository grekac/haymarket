{
  "name": "haymarket",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:socket": "tsx server/socket/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:socket\"",
    "build": "prisma generate && next build",
    "build:render": "prisma generate && prisma db push && next build",
    "start": "next start -H 0.0.0.0",
    "start:socket": "tsx server/socket/index.ts",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:setup": "prisma db push && npm run db:seed",
    "db:seed": "tsx prisma/seed.ts",
    "db:fetch-vehicles": "tsx scripts/fetch-vehicles.ts",
    "db:resolve-logos": "tsx scripts/resolve-logos.ts",
    "db:seed-gen-images": "tsx scripts/seed-generation-images.ts",
    "db:sync-group-photos": "tsx scripts/sync-group-photos.ts",
    "db:apply-all-photos": "tsx scripts/apply-all-photos.ts",
    "db:fix-generations": "tsx scripts/fix-generation-codes.ts",
    "db:full-sync": "tsx scripts/full-sync-generations.ts",
    "db:audit-generations": "tsx scripts/audit-all-generations.ts",
    "db:reset-photos": "tsx scripts/reset-wrong-photos.ts",
    "db:resolve-images": "tsx scripts/resolve-images.ts",
    "db:resolve-all": "tsx scripts/resolve-logos.ts && tsx scripts/seed-gen-images && tsx scripts/sync-group-photos && tsx scripts/apply-all-photos && tsx scripts/resolve-images.ts -- --popular --all --limit 5000",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@meterapp/vehicle-db": "^2.3.0",
    "@prisma/client": "^6.9.0",
    "auto-parts-db": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.6.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.12.0",
    "jose": "^6.2.3",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.19.4",
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "concurrently": "^9.1.2",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3"
  }
}
